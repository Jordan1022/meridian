# Database connection (VPS Postgres with TLS)
DATABASE_URL=postgresql://pb_user:your_strong_password@your_vps_ip:5432/pipeline_brain?sslmode=require

# App URL (CORS allow-origin for API middleware)
APP_URL=http://localhost:3000

# OpenClaw API token for CLI scripts (generate: openssl rand -hex 32)
OPENCLAW_TOKEN=your_64_character_hex_api_token_here

# Bootstrap credentials (one-time setup)
BOOTSTRAP_EMAIL=admin@example.com
BOOTSTRAP_PASSWORD=change_this_to_a_strong_password

# NextAuth.js Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
# For production: NEXTAUTH_URL=https://meridian.vercel.app
